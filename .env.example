# ==========================================
# HIDDEN APP - FRONTEND ENVIRONMENT VARIABLES
# ==========================================
# Cópialo como .env o .env.local para desarrollo.
# NUNCA subas el .env con valores reales a GitHub.

# URL base para exportar la bitácora a PDF (Apunta a tu Firebase Cloud Function)
VITE_PDF_EXPORT_URL=https://us-central1-[TU-PROYECTO].cloudfunctions.net/generateTripPdf

# Firebase Config (Si en el futuro deseas pasarlas a env variables)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Hackathon guest access (Anonymous Auth). Enabled by default; set to false after the event.
# VITE_ENABLE_GUEST_LOGIN=false
