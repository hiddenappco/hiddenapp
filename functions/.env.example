# ==========================================
# HIDDEN APP - BACKEND ENVIRONMENT VARIABLES
# ==========================================
# Archivo de ejemplo. Cópialo como .env para uso local.
# En producción, estas variables deben configurarse usando Google Cloud Secret Manager
# o Firebase Functions Config (ej. firebase functions:config:set google.maps_key="...")

# Requerido para getRouteAnalysis (Cálculo de peajes y tiempos de llegada)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Requerido para chatAgent y environmentalAgent (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key

# Requerido para getWeatherData (Clima Base)
ACCUWEATHER_API_KEY=your_accuweather_api_key

# Requerido para getMarineData (Mareas y Oleaje en destinos costeros)
STORMGLASS_API_KEY=your_stormglass_api_key
